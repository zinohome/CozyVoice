# ========== OpenAI（Whisper STT + Realtime） ==========
OPENAI_API_KEY=sk-REPLACE
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# ========== 腾讯云 TTS ==========
TENCENT_SECRET_ID=REPLACE
TENCENT_SECRET_KEY=REPLACE
TENCENT_REGION=ap-guangzhou

# ========== Brain 反向调用 ==========
BRAIN_URL=http://localhost:8000

# ========== CozyVoice 自身 ==========
VOICE_HOST=0.0.0.0
VOICE_PORT=8002
LOG_LEVEL=INFO

# ========== LiveKit（Agents Worker） ==========
# 开发：指向本 compose 内置 livekit-server（--dev 模式默认 devkey / secret）
# 生产：指向 LiveKit Cloud 或自部署实例
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
